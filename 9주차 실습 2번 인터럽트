int count = 0 ;
void LeftButton( void )
{
  count = count - 1 ;
}

void RightButton( void )
{
  count = count + 1 ;
}

void setup() {
  // put your setup code here, to run once:
  pinMode(2, INPUT) ;
  pinMode(3, INPUT) ;
  Serial.begin(9600) ;

  attachInterrupt( 0, LeftButton, FALLING ) ;
  attachInterrupt( 1, RightButton, CHANGE ) ;
}

void loop() {
  // put your main code here, to run repeatedly:
 Serial.println( count ) ;
}
