void setup() {
  // put your setup code here, to run once:
  pinMode(2, INPUT) ;
  pinMode(3, INPUT) ;
  Serial.begin(9600) ;
}

void loop() {
  // put your main code here, to run repeatedly:
  int left = digitalRead(2) ;
  int right = digitalRead(3) ;

  Serial.print("left = ") ;
  Serial.print( left ) ;
  Serial.print(", right = ") ;
  Serial.println( right ) ;

}
