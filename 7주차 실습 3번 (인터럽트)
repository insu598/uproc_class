void Test( void )
{
  Serial.println("Button") ;
}
void setup() {
  // put your setup code here, to run once:
pinMode(2, INPUT) ;
pinMode(9, OUTPUT) ;
Serial.begin(9600) ;

attachInterrupt(0, Test, RISING) ;
}

void loop() {
  // put your main code here, to run repeatedly:
digitalWrite( 9, 0 ) ;
delay(1000) ;
digitalWrite( 9, 1 ) ;
delay(1000) ;

}
