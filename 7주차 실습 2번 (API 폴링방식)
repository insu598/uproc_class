void setup() {
  // put your setup code here, to run once:
pinMode(8, INPUT) ;
pinMode(9, OUTPUT) ;
Serial.begin(9600) ;
}

void loop() {
  // put your main code here, to run repeatedly:
int Value ;
Value = digitalRead(8) ;
Serial.println( Value ) ;
if( Value == 0 )
{
 digitalWrite( 9, 0 ) ;  
}
else
{
 digitalWrite( 9, 1 ) ;
}

}
